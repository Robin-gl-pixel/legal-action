# Base URL de l'API FastAPI (server-side uniquement — pas de NEXT_PUBLIC_ par defaut).
API_BASE_URL=http://localhost:8000

# Supabase — exposes coté client
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Stripe (cles publiables)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Telemetrie front (optionnel)
NEXT_PUBLIC_APP_ENV=development
